#!/bin/bash
# tmux-new-session — create a named tmux session and open it in a new Kitty OS window
set -euo pipefail

session_name="${1:-}"

if [ -z "$session_name" ]; then
  echo "Usage: tmux-new-session <session-name>" >&2
  exit 1
fi

# Create detached session if it doesn't already exist
tmux new-session -d -s "$session_name" 2>/dev/null || true

# Open a new Kitty OS window that safe-attaches to the session
kitty --single-instance -e attach "$session_name"
