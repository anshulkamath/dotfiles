#!/bin/bash
# tmux-help — show a cheatsheet of custom tmux bindings

cat << 'EOF' | fzf \
  --no-sort --no-select-1 --no-multi \
  --layout=reverse-list \
  --prompt=" tmux help  " \
  --header="$(printf 'prefix = ctrl+a   |   q / esc to close')" \
  --preview-window=hidden \
  --color='header:italic:dim' \
  --bind='enter:ignore,q:abort,esc:abort'

 SPLITS & NAVIGATION
   prefix + |          split horizontal
   prefix + -          split vertical
   prefix + m          zoom / unzoom pane
   prefix + !          break pane → new window
   ctrl + h/j/k/l      navigate panes (vim-style, no prefix)

 PANE LAYOUT
   prefix + h/j/k/l    move pane in direction (reflows layout if no neighbor)
   prefix + H/J/K/L    resize pane

 PANE MANAGEMENT
   prefix + P          pull a pane from any session → here (fzf)
   prefix + S          send current pane → any window (fzf)
   prefix + D          detach pane → standalone session (named after cwd)

 WINDOW MANAGEMENT
   prefix + c          new window
   prefix + n / p      next / previous window
   prefix + T          move window → another session (fzf)
   prefix + W          swap window with another in this session (fzf)

 SESSIONS
   prefix + N          new window → opens in a new Kitty tab
   prefix + s          interactive session + window tree
   prefix + d          detach (session stays alive)

 SCRATCH POPUPS
   prefix + g          scratch popup (current dir); splits pane if already in scratch
   prefix + G          git scratch (current dir)

 PROJECT SWITCHER  (ctrl+])
   ctrl+] → n          notes  ~/Developer/personal/notes
   ctrl+] → .          dotfiles  ~/Developer/public/dotfiles
   ctrl+] → o          fzf pick any dir in ~/Developer → new Kitty tab

 CLAUDE PROJECTS  (ctrl+\)
   ctrl+\ → n          notes
   ctrl+\ → .          dotfiles
   ctrl+\ → f          foundry
   ctrl+\ → s          systems
   ctrl+\ → a          network-artifacts
   ctrl+\ → o          fzf pick any dir in ~/Developer

 COPY MODE
   prefix + [          enter copy mode
   v                   begin selection
   y                   copy to clipboard (pbcopy)
   ctrl + space        send ctrl+l (clear screen)

 META
   prefix + r          reload config
   prefix + ?          this help
EOF
