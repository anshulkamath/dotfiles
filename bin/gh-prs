#!/usr/bin/env python3
"""gh-prs — fzf overview of open PRs in the current repo."""

import json
import subprocess
import sys
import os

GREEN  = '\033[0;32m'
YELLOW = '\033[0;33m'
RED    = '\033[0;31m'
CYAN   = '\033[0;36m'
WHITE  = '\033[0;97m'
DIM    = '\033[2;37m'
RESET  = '\033[0m'
BOLD   = '\033[1m'

QUERY = '''
query($repo: String!, $owner: String!) {
  repository(owner: $owner, name: $repo) {
    pullRequests(states: OPEN, first: 50, orderBy: {field: UPDATED_AT, direction: DESC}) {
      nodes {
        number title url isDraft reviewDecision mergeable
        commits(last: 1) {
          nodes { commit { statusCheckRollup { state } } }
        }
      }
    }
  }
}
'''

def get_current_repo():
    r = subprocess.run(['gh', 'repo', 'view', '--json', 'nameWithOwner', '-q', '.nameWithOwner'],
                       capture_output=True, text=True)
    if r.returncode != 0:
        return None, None
    nwo = r.stdout.strip()
    parts = nwo.split('/')
    return (parts[0], parts[1]) if len(parts) == 2 else (None, None)

def fmt_status(pr):
    if pr.get('isDraft'):
        return DIM, '⊘ draft'
    return GREEN, '● open '

def fmt_ci(pr):
    try:
        state = pr['commits']['nodes'][0]['commit']['statusCheckRollup']['state']
    except (KeyError, IndexError, TypeError):
        state = None
    if state == 'SUCCESS': return GREEN,  '✓ ci'
    if state == 'FAILURE': return RED,    '✗ ci'
    if state == 'PENDING': return YELLOW, '⏳ ci'
    return DIM, '· ci'

def fmt_review(pr):
    d = pr.get('reviewDecision') or ''
    if d == 'APPROVED':          return GREEN,  '✓ rev'
    if d == 'CHANGES_REQUESTED': return RED,    '✗ rev'
    if d == 'REVIEW_REQUIRED':   return YELLOW, '? rev'
    return DIM, '· rev'

def fmt_merge(pr):
    m = pr.get('mergeable') or ''
    if m == 'CONFLICTING': return RED,   '⚡'
    if m == 'MERGEABLE':   return GREEN, '✓'
    return DIM, '·'

def col(color, text):
    return f'{color}{text}{RESET}'

def fetch_fzf_input(owner, repo):
    raw = subprocess.run(
        ['gh', 'api', 'graphql',
         '-f', f'query={QUERY}',
         '-f', f'repo={repo}',
         '-f', f'owner={owner}'],
        capture_output=True, text=True
    )
    if raw.returncode != 0:
        return None, raw.stderr.strip()

    data = json.loads(raw.stdout)
    prs = data['data']['repository']['pullRequests']['nodes']

    header = f'{"STATUS":<7} {"CI":<5} {"REV":<6} {"M":<2}  {"#":<7}  TITLE'

    if not prs:
        return f'__hdr__\t{header}\n__empty__\t{DIM}no open PRs in {owner}/{repo}{RESET}', None

    lines = []
    for pr in prs:
        sc, st = fmt_status(pr)
        cc, ct = fmt_ci(pr)
        rc, rt = fmt_review(pr)
        mc, mt = fmt_merge(pr)
        num    = str(pr['number'])
        title  = pr['title']
        url    = pr['url']

        # Fixed-width plain text first, then wrap in color — keeps alignment intact
        display = (
            f'{col(sc, f"{st:<7}")} '
            f'{col(cc, f"{ct:<5}")} '
            f'{col(rc, f"{rt:<6}")} '
            f'{col(mc, f"{mt:<2}")}  '
            f'{col(BOLD, f"#{num:<6}")}  '
            f'{title}'
        )
        lines.append(f'{url}\t{display}')

    return f'__hdr__\t{header}\n' + '\n'.join(lines), None


def main():
    list_only = '--list-only' in sys.argv

    owner, repo = get_current_repo()
    if not owner:
        print(f'{RED}not inside a GitHub repo{RESET}')
        sys.exit(1)

    fzf_input, err = fetch_fzf_input(owner, repo)
    if err:
        print(f'{RED}gh api failed:{RESET} {err}')
        sys.exit(1)

    if list_only:
        print(fzf_input, end='')
        return

    script = os.path.abspath(__file__)

    result = subprocess.run(
        ['fzf',
         '--ansi', '--no-sort', '--no-multi',
         '--layout=reverse-list', '--header-lines=1',
         '--delimiter=\t', '--with-nth=2',
         f'--prompt= {owner}/{repo}  ',
         '--header=enter → open in browser   r → reload   q/esc → close\n'
         'status: ● open  ⊘ draft\n'
         'ci:     ✓ pass  ✗ fail  ⏳ pending  · none\n'
         'rev:    ✓ approved  ✗ changes requested  ? required  · none\n'
         'M:      ✓ mergeable  ⚡ conflict  · unknown',
         '--color=header:italic:dim',
         f'--bind=r:reload({script} --list-only)',
         '--bind=q:abort,esc:abort'],
        input=fzf_input, text=True, stdout=subprocess.PIPE
    )

    selected = (result.stdout or '').strip()
    if not selected:
        return

    url = selected.split('\t')[0]
    if url and url != '__hdr__':
        subprocess.run(['open', url])

if __name__ == '__main__':
    try:
        main()
    except Exception as e:
        import traceback
        print(f'\n{RED}crash:{RESET} {e}\n')
        traceback.print_exc()
        input('\npress enter to close...')
